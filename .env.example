# Port the app listens on (serves both the API and the built client).
PORT=5001

# Path to the SQLite database file. Defaults to ./data.db if unset.
DATABASE_PATH=./data.db

# Directory where uploaded attachments (quotes, delivery notes, invoice scans) are stored.
# Defaults to ./uploads if unset.
UPLOADS_DIR=./uploads

# Enables the one-click demo-user switcher on the login page (GET /api/users returns
# name/role/email for all users, unauthenticated). Only for local dev/demo — leave unset
# (or set to false) on a real production deploy so user emails aren't publicly listable.
DEMO_MODE=true

# Number of trusted reverse-proxy hops in front of this app (sets Express "trust proxy").
# Only set this when actually deployed behind a reverse proxy/load balancer — otherwise
# rate limiting will bucket by the proxy's IP instead of the real client IP. Leave unset
# if the app is reachable directly, since trusting X-Forwarded-For without a real proxy
# in front lets clients spoof their IP and dodge rate limiting.
TRUST_PROXY_HOPS=1

# Amazon Business Punch-Out (cXML). Leave PUNCHOUT_SUPPLIER_SETUP_URL unset to use the
# built-in mock supplier bundled in this app (server/routes.ts's mock-amazon endpoints), so
# the full PunchOutSetupRequest/Response + PunchOutOrderMessage round-trip can be exercised
# without a real Amazon Business account. Once Amazon issues real punch-out credentials, set
# these to the values Amazon provides and PUNCHOUT_SUPPLIER_SETUP_URL to Amazon's real cXML
# endpoint — expect the exact cXML shape may still need minor adjustment to match Amazon's DTD.
PUNCHOUT_SUPPLIER_SETUP_URL=
PUNCHOUT_SHARED_SECRET=demo-shared-secret
PUNCHOUT_OUR_IDENTITY=OUNDA-PROCURE

# Public origin used to build absolute URLs the punch-out protocol requires (the callback URL
# sent to the supplier, the StartPage URL sent back to the browser). Leave unset to derive it
# from the incoming request's Host header (fine for local dev); set explicitly in production.
APP_ORIGIN=
